PG_HOST: localhost
PG_PORT: 5432
PG_USER: postgres
PG_PASSWORD: postgres
PG_DBNAME: defaultdb
PG_SSLMODE: disable

# Optional: trigger a stats-web build+deploy after rankings update
# DEPLOY_SCRIPT defaults to /scripts/deploy-web.sh inside the container
DEPLOY_SCRIPT=
CF_PAGES_PROJECT=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
